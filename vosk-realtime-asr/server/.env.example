# 火山引擎 (字节跳动开放平台) 实时语音识别 API 凭据
# 在火山引擎控制台创建应用后获取: https://console.volcengine.com/
# 真实凭据请放在同目录的 .env 文件中（已被 .gitignore 排除），不要提交到仓库。

# --- 鉴权 ---
VOLC_APP_KEY=your_volc_app_key_here
VOLC_ACCESS_TOKEN=your_volc_access_token_here

# --- 资源 ID（决定调用哪个服务）---
# bigmodel                = 流式语音识别 (推荐, 默认, 支持 show_utterances 分角色)
# volc.service_type.10053 = 豆包同声传译 AST 2.0 (LLM 翻译, 需要 s2t 模式)
# volc.seedasr.sauc.duration = 流式语音识别 (老版本)
VOLC_RESOURCE_ID=bigmodel

# --- 端点（一般不用改）---
# v3/sauc/bigmodel_async = 流式语音识别 (推荐)
# v3/sauc/translation    = 豆包同声传译
VOLC_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async

# --- 模型名（一般不用改）---
VOLC_MODEL_NAME=bigmodel

# --- 豆包同声传译 s2t 模式额外参数（仅资源 ID = volc.service_type.10053 时需要）---
# VOLC_EXTRA_REQUEST={"mode":"s2t","source_language":"zh","target_language":"en"}

# --- 火山引擎 语音合成 2.0 (SeedTTS 2.0) — 2026-06-27 ---
# 在 火山引擎控制台 → 大模型语音合成 2.0 → 应用管理 创建应用后获取:
# https://console.volcengine.com/speech/service/tts
# 凭证仅服务端持有, 浏览器经 /api/tts/* 走代理, 前端永不直连.
VOLC_TTS_APP_ID=
VOLC_TTS_TOKEN=
# 火山引擎 cluster (默认 volcano_tts)
VOLC_TTS_CLUSTER=volcano_tts
# TTS endpoint (一般不用改)
VOLC_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v1/tts
# 默认音色 (BV001_streaming = 磁性男声)
VOLC_TTS_VOICE=BV001_streaming
# 默认输出格式 (mp3 / pcm / wav)
VOLC_TTS_DEFAULT_FORMAT=mp3

# --- 同声传译 2.0 (volc.translate.s2t.v2) ---
# 在火山引擎控制台 → 语音技术 → 同声传译 → 应用管理 获取:
# https://console.volcengine.com/speech/service/translate
VOLC_TRANSLATE_APP_ID=
VOLC_TRANSLATE_TOKEN=
# 翻译端点 (一般不用改)
VOLC_TRANSLATE_ENDPOINT=https://openspeech.bytedance.com/api/v2/simultaneous
# 翻译资源 ID (一般不用改)
VOLC_TRANSLATE_RESOURCE_ID=volc.translate.s2t.v2
