# ============================================================================
# NestJS 后端环境变量样例
# 复制为 .env 并填入真实值. .env 已在 .gitignore 中, 不会进 git.
# ============================================================================

# ---- 服务 ----
HOST=0.0.0.0
PORT=5001
LOG_LEVEL=info
PROMETHEUS_PORT=9092

# ---- 火山引擎 ASR (流式语音识别, v3/sauc 协议) ----
# 二选一: 新控制台单一 API Key (推荐), 或旧版双鉴权
VOLC_API_KEY=
VOLC_APP_KEY=
VOLC_ACCESS_TOKEN=
VOLC_RESOURCE_ID=volc.seedasr.sauc.duration
VOLC_MODEL_NAME=bigmodel
VOLC_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async

# ---- 火山引擎 TTS (V3 WS 双向流式, doc 1329505) ----
# V3 协议: X-Api-App-Key + X-Api-Key 鉴权.
# 注: 同一个 VOLC_API_KEY 通常同时具备 ASR + TTS 权限, 无需单独申请 TTS key.
#     如需隔离, 用 VOLC_TTS_API_KEY 覆盖.
VOLC_TTS_API_KEY=
# Resource-Id — 大模型 TTS 双向流式固定值 (doc 1329505)
VOLC_TTS_RESOURCE_ID=volc.service_type.10029
# 默认音色 (zh_male_M392_conversation_wvae_bigtts = 普通话男声会话音色, 实测可用)
VOLC_TTS_SPEAKER=zh_male_M392_conversation_wvae_bigtts
# 端点 (V3 WS bidirection)
VOLC_TTS_ENDPOINT=wss://openspeech.bytedance.com/api/v3/tts/bidirection

# ---- TTS pipeline ----
# 每句 final 后是否自动触发 TTS (客户端也可在 start_recording 里覆盖)
TTS_ENABLED=true
# 单次 TTS 调用超时 (毫秒)
TTS_TIMEOUT_MS=5000
# 同句去重 LRU 容量
TTS_CACHE_SIZE=200
