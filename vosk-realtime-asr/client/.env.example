# 火山引擎 SeedTTS 2.0 (语音合成 2.0) — 前端配置
# 真实凭据请放 .env (已 .gitignore), 不要提交到仓库.
#
# 本前端只持有路由前缀 + 默认音色, 不持有任何凭证.
# 真实凭证 (VOLC_TTS_APP_ID / TOKEN) 走 server/.env, 经 /api/tts/* 代理.

# TTS 后端路由前缀 (vite dev 时由 vite.config.ts 的 /api 代理到 Flask:5000)
VITE_TTS_BASE=/api/tts

# 默认音色 (BV001_streaming = 磁性男声)
VITE_TTS_DEFAULT_VOICE=BV001_streaming

# 默认语速 (0.5 ~ 2.0)
VITE_TTS_DEFAULT_SPEED=1.0

# 默认音调 (0.5 ~ 2.0)
VITE_TTS_DEFAULT_PITCH=1.0

# 默认音频格式 (mp3 / pcm / wav)
VITE_TTS_DEFAULT_FORMAT=mp3
